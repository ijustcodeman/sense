<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#121212"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Shake Speed Tracker"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvHighscoreLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Highscore:"
        android:textSize="18sp"
        android:textColor="#E0E0E0"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvHighscoreValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:layout_constraintBaseline_toBaselineOf="@id/tvHighscoreLabel"
        app:layout_constraintStart_toEndOf="@id/tvHighscoreLabel"
        android:layout_marginStart="8dp" />

    <TextView
        android:id="@+id/tvLastAttemptLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last Attempt:"
        android:textSize="16sp"
        android:textColor="#B0B0B0"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvHighscoreLabel"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvLastAttemptValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="16sp"
        android:textColor="#B0B0B0"
        app:layout_constraintBaseline_toBaselineOf="@id/tvLastAttemptLabel"
        app:layout_constraintStart_toEndOf="@id/tvLastAttemptLabel"
        android:layout_marginStart="8dp" />

    <ProgressBar
        android:id="@+id/pbHighscore"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:layout_marginTop="32dp"
        android:max="5000"
        android:progress="0"
        app:layout_constraintTop_toBottomOf="@id/tvLastAttemptLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <CheckBox
        android:id="@+id/cbGravity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable Gravity (-100/s)"
        android:textColor="#FFFFFF"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/pbHighscore"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnRestart"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Restart"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cbGravity"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>